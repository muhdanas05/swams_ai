        "message": "=<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;\">\n  \n  <h2 style=\"color: #2c3e50;\">⚡ New Police Report – Verification Required</h2>\n  \n  <p>A new police report has been processed for <strong>{{ $('Get Contact ID').item.json.data[0].name }}</strong>. Please review the extracted data and take action using the link below.</p>\n\n  <p>Once you approve, the system will automatically:</p>\n  <ul>\n    <li>Update the Matter in Clio</li>\n    <li>Generate and store the Retainer Agreement</li>\n    <li>Add SOL date to Andrew's calendar</li>\n    <li>Send personalized email to the client</li>\n  </ul>\n\n  <div style=\"margin: 30px 0; text-align: center;\">\n    <a href=\"{{ $json.form_url }}\" \n       style=\"background-color: #27ae60; color: white; padding: 14px 30px; \n              text-decoration: none; border-radius: 5px; font-size: 16px; font-weight: bold;\">\n      ✅ Review & Approve / Reject\n    </a>\n  </div>\n\n  <p style=\"color: #999; font-size: 12px;\">This email was generated automatically by the Richards & Law intake system. Do not reply.</p>\n\n</div>",
